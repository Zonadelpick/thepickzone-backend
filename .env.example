# =============================
# Base app
# =============================
NODE_ENV=development
PORT=3001
JWT_SECRET=replace_with_a_strong_random_secret
FRONTEND_BASE_URL=http://localhost:3000
# FRONTEND_URL=http://localhost:3000
# APP_BASE_URL=http://localhost:3000

# =============================
# MongoDB (define UNA de estas)
# =============================
MONGO_URI=mongodb://localhost:27017/thepickzone
# MONGODB_URI=
# DATABASE_URL=

# =============================
# Stripe (pagos)
# Requerido: al menos una secret key.
# Recomendado: usar STRIPE_SECRET_KEY.
# =============================
STRIPE_SECRET_KEY=sk_test_replace_me
# STRIPE_MODE=test
# STRIPE_TEST_SECRET_KEY=sk_test_replace_me
# STRIPE_LIVE_SECRET_KEY=sk_live_replace_me
# STRIPE_SECRET_KEY_TEST=sk_test_replace_me
# STRIPE_SECRET_KEY_LIVE=sk_live_replace_me
# STRIPE_REQUIRE_LIVE=false
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
# STRIPE_PRO_PRICE_ID=price_replace_me

# =============================
# Email (Resend)
# Si no configuras Resend, el backend no enviará correos.
# =============================
# RESEND_API_KEY=re_replace_me
# RESEND_API_TOKEN=re_replace_me
# RESEND_KEY=re_replace_me
# EMAIL_FROM=The Pick Zone <noreply@your-domain.com>
# RESEND_FROM=The Pick Zone <noreply@your-domain.com>
# RESEND_FROM_EMAIL=The Pick Zone <noreply@your-domain.com>
# RESEND_SENDER=The Pick Zone <noreply@your-domain.com>
# AUTH_REQUIRE_EMAIL_VERIFICATION=true

# =============================
# Proveedores deportivos / IA
# =============================
ODDS_API_KEY=replace_with_odds_api_key
# ANTHROPIC_API_KEY=replace_with_anthropic_key
# GOOGLE_VISION_KEY=replace_with_google_vision_key
# APISPORTS_KEY=replace_with_apisports_key
# APISPORTS_API_KEY=replace_with_apisports_key
# APISPORTS_BASKETBALL_BASE_URL=https://v1.basketball.api-sports.io
# APISPORTS_BASEBALL_BASE_URL=https://v1.baseball.api-sports.io
# APISPORTS_AMERICAN_FOOTBALL_BASE_URL=https://v1.american-football.api-sports.io
# APISPORTS_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# =============================
# IA / verificación de picks
# =============================
# true => nunca autocierra; false => permite cierre automático cuando el partido termina y la confianza es suficiente.
PICK_AI_MANUAL_AUTH_ONLY=false
# AUTO_CLOSE_MIN_EXTRACTION_QUALITY=55
# AUTO_CLOSE_MIN_EVENT_MATCH_QUALITY=60
# AUTO_CLOSE_MIN_OFFICIAL_DATA_QUALITY=70
# PICK_PENDING_STALE_HOURS=12
# PICK_REVIEW_STALE_HOURS=6
# PICK_ALERT_LOOKBACK_HOURS=24
# PICK_ANALYSIS_INTERVAL_MS=300000
# PICK_ANALYSIS_RECHECK_MINUTES=30
# PICK_ANALYSIS_MIN_AGE_MINUTES=0
# PICK_ANALYSIS_BATCH_LIMIT=200

# =============================
# Payout semanal tipsters
# =============================
# WEEKLY_PAYOUT_MIN_CENTS=2000
# WEEKLY_PAYOUT_RUN_LIMIT=150
